{
  "name": "mjolnirsoft-session-view",
  "displayName": "Mjolnirsoft Session View",
  "description": "Render a Mjolnirsoft executor session as Markdown and Mermaid.",
  "version": "0.0.4",
  "private": true,
  "publisher": "mjolnirsoft",
  "engines": {
    "vscode": "^1.84.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mjolnirsoft.openSessionView",
        "title": "Mjolnirsoft: Open Session View"
      },
      {
        "command": "mjolnirsoft.startExecutorSession",
        "title": "Mjolnirsoft: Start Executor Session"
      },
      {
        "command": "mjolnirsoft.startOrchestratorSession",
        "title": "Mjolnirsoft: Start Orchestrator Session"
      }
    ]
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "node esbuild.mjs"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.28.1",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0"
  }
}
